{
  "settings": {
    "languages": [
      "fr"
    ],
    "forceNER": true,
    "nlu": {
      "log": true
    },
    "ner": {
      "builtins": [
        "number",
        "date",
        "time",
        "email",
        "url",
        "phone"
      ],
      "threshold": 0.7
    },
    "tag": "nlp",
    "threshold": 0.5,
    "autoLoad": true,
    "autoSave": true,
    "modelFileName": "model.nlp",
    "executeActionsBeforeAnswers": false,
    "calculateSentiment": true
  },
  "nluManager": {
    "settings": {
      "tag": "nlu-manager",
      "log": true
    },
    "locales": [
      "fr"
    ],
